---
export interface Props {
  /** Número de teléfono en formato internacional, solo dígitos (sin +, espacios ni guiones). Ej: "5233XXXXXXXX" */
  phone: string;
  /** Mensaje precargado que aparecerá en el chat de WhatsApp */
  message?: string;
}

const {
  phone,
  message = "Hola!, me gustaría obtener más información sobre sus terapias y productos.",
} = Astro.props;

// wa.me solo acepta dígitos en el número (sin '+', espacios ni guiones)
const cleanPhone = phone.replace(/\D/g, "");
const whatsappUrl = `https://wa.me/${cleanPhone}?text=${encodeURIComponent(message)}`;
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="wa-float-btn"
  aria-label="Chatea con nosotros por WhatsApp"
>
  <span class="wa-float-btn__pulse" aria-hidden="true"></span>
  <svg
    class="wa-float-btn__icon"
    viewBox="0 0 32 32"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    focusable="false"
  >
    <path
      fill="currentColor"
      d="M16.004 3C9.377 3 4 8.373 4 15c0 2.362.687 4.564 1.872 6.415L4 29l7.767-1.83A11.94 11.94 0 0 0 16.004 27C22.63 27 28 21.627 28 15S22.63 3 16.004 3Zm0 21.818a9.77 9.77 0 0 1-4.98-1.366l-.357-.212-4.61 1.087 1.104-4.49-.234-.367A9.76 9.76 0 0 1 5.2 15c0-5.966 4.847-10.818 10.804-10.818S26.809 9.034 26.809 15 21.961 24.818 16.004 24.818Zm5.61-7.98c-.307-.154-1.816-.897-2.098-1-.28-.103-.485-.154-.688.154-.204.307-.79 1-.968 1.205-.178.205-.357.23-.663.077-.307-.154-1.296-.478-2.468-1.523-.912-.813-1.528-1.817-1.707-2.124-.178-.307-.019-.473.135-.626.139-.138.307-.359.46-.538.154-.18.205-.308.307-.513.103-.205.051-.384-.026-.538-.077-.154-.688-1.659-.943-2.272-.248-.596-.5-.516-.688-.526l-.586-.01c-.205 0-.538.077-.82.384-.28.307-1.07 1.046-1.07 2.551 0 1.505 1.096 2.96 1.249 3.164.153.205 2.157 3.294 5.228 4.62.73.315 1.3.503 1.744.643.733.233 1.4.2 1.928.121.588-.088 1.816-.742 2.072-1.459.256-.717.256-1.331.18-1.459-.077-.128-.281-.205-.588-.359Z"
    />
  </svg>
</a>

<style>
  .wa-float-btn {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 9999px;
    background-color: #25d366;
    color: #ffffff;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    isolation: isolate;
  }

  .wa-float-btn:hover {
    transform: scale(1.08);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
  }

  .wa-float-btn:active {
    transform: scale(0.96);
  }

  .wa-float-btn__icon {
    position: relative;
    z-index: 1;
    width: 1.8rem;
    height: 1.8rem;
  }

  /* Efecto de pulso puramente CSS, sin JavaScript */
  .wa-float-btn__pulse {
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background-color: #25d366;
    z-index: 0;
    animation: wa-pulse 2.2s ease-out infinite;
  }

  @keyframes wa-pulse {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    100% {
      transform: scale(1.9);
      opacity: 0;
    }
  }

  @media (max-width: 640px) {
    .wa-float-btn {
      right: 1rem;
      bottom: 1rem;
      width: 3.25rem;
      height: 3.25rem;
    }
    .wa-float-btn__icon {
      width: 1.6rem;
      height: 1.6rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wa-float-btn__pulse {
      animation: none;
    }
  }
</style>
