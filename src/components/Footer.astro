---
const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/nosotros', label: 'Nosotros' },
  { href: '/terapias', label: 'Terapias' },
  { href: '/productos', label: 'Productos' },
  { href: '/blog', label: 'Blog' },
  { href: '/contacto', label: 'Contacto' },
];

const year = new Date().getFullYear();
---

<footer class="bg-deep-900 text-deep-300">
  <div class="container-custom section-padding">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/logoimhdxein.png" alt="IMHDXEIN" class="w-12 h-12" />
          <div>
            <span class="text-xl font-heading font-bold text-white">IMHDXEIN</span>
            <span class="block text-[10px] text-deep-400 tracking-[0.2em] uppercase -mt-1">Medicina Integrativa</span>
          </div>
        </div>
        <p class="text-deep-400 text-sm leading-relaxed">
          Instituto de Medicina Holística dedicado a la sanación integral del ser.
          Integrando tradiciones milenarias con ciencia contemporánea.
        </p>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4">Navegación</h4>
        <ul class="space-y-2">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-deep-400 hover:text-brand-400 transition-colors text-sm">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4">Terapias</h4>
        <ul class="space-y-2 text-deep-400 text-sm">
          <li>Alineación de Chakras</li>
          <li>Flores de Bach</li>
          <li>Aromaterapia</li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4">Contacto</h4>
        <ul class="space-y-3 text-deep-400 text-sm">
          <li class="flex items-center gap-2"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg> +52 33 1842 2251</li>
          <li class="flex items-center gap-2"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg> imhdxein@gmaill.com.com</li>
          <li class="flex items-center gap-2"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg> Calle Buenos Aires 2910, Colonia Providencia, Guadalajara Jalisco CP 66439</li>
        </ul>
      </div>
    </div>
    <div class="mt-12 pt-8 border-t border-deep-800">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-deep-500 text-xs">&copy; {year} IMHDXEIN - Instituto de Medicina Holística. Todos los derechos reservados.</p>
        <div class="flex items-center gap-1">
          <span class="w-4 h-1 rounded-full bg-chakra-root"></span>
          <span class="w-4 h-1 rounded-full bg-chakra-sacral"></span>
          <span class="w-4 h-1 rounded-full bg-chakra-solar"></span>
          <span class="w-4 h-1 rounded-full bg-chakra-heart"></span>
          <span class="w-4 h-1 rounded-full bg-chakra-throat"></span>
          <span class="w-4 h-1 rounded-full bg-chakra-third"></span>
          <span class="w-4 h-1 rounded-full bg-chakra-crown"></span>
        </div>
      </div>
    </div>
  </div>
</footer>
