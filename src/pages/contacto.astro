---
export const prerender = true;

import MainLayout from '../layouts/MainLayout.astro';
import ContactForm from '../components/ContactForm.vue';
import { getCollection } from 'astro:content';

const therapyEntries = (await getCollection('therapies', ({ data }) => data.isActive))
  .sort((a, b) => a.data.orderIndex - b.data.orderIndex);

const therapyOptions = therapyEntries.map((t) => ({
  id: t.id,
  name: t.data.name,
  durationMinutes: t.data.durationMinutes,
}));
---

<MainLayout
  title="Contacto - IMHDXEIN | Terapias Holísticas"
  description="Envíanos un mensaje y nos comunicaremos contigo. Terapias holísticas en Guadalajara Jalisco. Acupuntura, Reiki, Flores de Bach y más."
>
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-chakra-root/70 via-brand-900 to-deep-900"></div>
    <div class="absolute inset-0 lotus-bg opacity-20"></div>
    <div class="container-custom px-4 relative z-10">
      <div class="max-w-3xl">
        <span class="text-brand-300 text-sm font-semibold tracking-wider uppercase">Contacto</span>
        <h1 class="mt-3 text-4xl md:text-5xl font-heading font-bold text-white">Estamos aquí <span class="chakra-gradient-text">para ti</span></h1>
        <p class="mt-6 text-deep-200 text-lg leading-relaxed">Envíanos un mensaje y nos comunicaremos contigo para acordar los detalles de tu cita.</p>
      </div>
    </div>
  </section>
  <div class="h-1.5 chakra-gradient"></div>

  <ContactForm client:load therapies={therapyOptions} />

  <div class="h-1 chakra-gradient"></div>

  <!-- Location / Map -->
  <section class="section-padding bg-brand-50 relative overflow-hidden">
    <div class="container-custom relative z-10">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <span class="text-spirit-600 text-sm font-semibold tracking-wider uppercase">Ubícanos</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-heading font-bold text-deep-900">
          Cómo <span class="chakra-gradient-text">llegar</span>
        </h2>
        <p class="mt-4 text-deep-500 leading-relaxed">
          Visítanos en nuestro espacio de sanación integral en Guadalajara, Jalisco.
        </p>
      </div>

      <div class="max-w-5xl mx-auto">
        <div class="bg-white rounded-3xl shadow-xl overflow-hidden">
          <div class="w-full h-[420px]">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3732.317620497016!2d-103.3856165!3d20.697322999999997!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8428ae4625e8a735%3A0x1a232965cf93d269!2sBuenos%20Aires%202910%2C%20Providencia%204a.%20Secc%2C%2066439%20Guadalajara%2C%20Jal.!5e0!3m2!1ses-419!2smx!4v1783284553950!5m2!1ses-419!2smx"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="strict-origin-when-cross-origin"
              title="Ubicación de IMHDXEIN en Google Maps"
            ></iframe>
          </div>

          <div class="p-6 md:p-8 flex flex-col md:flex-row items-center md:items-center justify-between gap-6 bg-gradient-to-br from-brand-100 via-brand-50 to-spirit-100">

            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-brand-400 to-spirit-500 flex items-center justify-center shrink-0">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <div>
                <p class="text-deep-400 text-xs uppercase tracking-wider font-medium">Dirección</p>
                <p class="text-deep-800 font-heading font-semibold">Calle Buenos Aires 2910, Col. Providencia</p>
                <p class="text-deep-500 text-sm">CP 66439, Guadalajara, Jalisco</p>
              </div>
            </div>
            <a
              href="https://maps.app.goo.gl/DztsAwGsFNfEExTu6"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary flex items-center gap-2 shrink-0"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                <path d="M19.5 10.5c0 7-7.5 11-7.5 11S4.5 17.5 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
              </svg>
              Cómo llegar
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
