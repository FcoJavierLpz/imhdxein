---
export const prerender = true;

import MainLayout from '../layouts/MainLayout.astro';
import TherapySelector from '../components/TherapySelector.vue';
import { getCollection } from 'astro:content';

const therapyEntries = (await getCollection('therapies', ({ data }) => data.isActive))
  .sort((a, b) => a.data.orderIndex - b.data.orderIndex);

const therapies = therapyEntries.map((t) => ({
  id: t.id,
  slug: t.id,
  ...t.data,
  image: t.data.image?.src,

  price: t.data.price ?? null,
}));
---

<MainLayout
  title="Terapias Holísticas - IMHDXEIN | Alineación de Chakras, Flores de Bach y más"
  description="Explora nuestras terapias holísticas: Alineación de Chakras, Flores de Bach, Aromaterapia, y Medicina Integrativa. Agenda tu cita."
>
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-800 via-brand-900 to-deep-900"></div>
    <div class="absolute inset-0 lotus-bg opacity-20"></div>
    <div class="container-custom px-4 relative z-10">
      <div class="max-w-3xl">
        <span class="text-brand-300 text-sm font-semibold tracking-wider uppercase">Nuestras Terapias</span>
        <h1 class="mt-3 text-4xl md:text-5xl font-heading font-bold text-white">Terapias <span class="chakra-gradient-text">holísticas</span></h1>
        <p class="mt-6 text-brand-100 text-lg leading-relaxed">Explora nuestras modalidades terapéuticas y encuentra la que resuena con tu proceso de sanación.</p>
      </div>
    </div>
  </section>
  <div class="h-1.5 chakra-gradient"></div>

  {therapies.length > 0 ? (
    <TherapySelector client:load therapies={therapies} />
  ) : (
    <section class="section-padding bg-white">
      <div class="container-custom">
        <p class="text-center text-deep-400 py-12">Próximamente publicaremos nuestras terapias.</p>
      </div>
    </section>
  )}
</MainLayout>
