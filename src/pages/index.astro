---
export const prerender = true;

import MainLayout from '../layouts/MainLayout.astro';

import TestimonialCarousel from '../components/TestimonialCarousel.vue';
import HeroSlider from '../components/HeroSlider.vue';
import { getCollection } from 'astro:content';

const therapyEntries = (await getCollection('therapies', ({ data }) => data.isActive))
  .sort((a, b) => a.data.orderIndex - b.data.orderIndex);
const therapies = therapyEntries.map((t) => ({
  id: t.id,
  slug: t.id,
  ...t.data,
  price: t.data.price ?? null,
}));

const testimonialEntries = await getCollection('testimonials', ({ data }) => data.isVisible);
const testimonials = testimonialEntries.map((t) => ({
  id: t.id,
  name: t.data.name,
  text: t.data.text,
  rating: t.data.rating,
  therapy: t.data.therapy,
}));


const chakraColors = [
  'from-chakra-root to-chakra-sacral',
  'from-chakra-sacral to-chakra-solar',
  'from-chakra-solar to-chakra-heart',
  'from-chakra-heart to-chakra-throat',
  'from-chakra-throat to-chakra-third',
  'from-chakra-third to-chakra-crown',
  'from-chakra-crown to-spirit-600',
  'from-spirit-600 to-chakra-root',
];

const iconSvg = (name: string) => {
  const icons: Record<string, string> = {
    Sparkles: '<path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/>',
    Flower2: '<path d="M12 5a3 3 0 1 1 3 3m-3-3a3 3 0 1 0-3 3m3-3v0M12 5a3 3 0 0 0-3 3v6a3 3 0 0 0 3 3m0-12c1.657 0 3 1.343 3 3v6c0 1.657-1.343 3-3 3m0-12c-1.657 0-3 1.343-3 3v6c0 1.657 1.343 3 3 3m0 0a3 3 0 0 0 3-3"/><path d="M12 17a3 3 0 0 1-3-3"/>',
    Hand: '<path d="M18 11V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2"/><path d="M14 10V4a2 2 0 0 0-2-2a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/>',
    Brain: '<path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .583-.786"/><path d="M19.94 10.11a4 4 0 0 1 .583.786"/><path d="M6.399 15.5a3 3 0 0 0-.399 1.375"/><path d="M17.601 15.5a3 3 0 0 0 .399 1.375"/><path d="M20.523 15.104a4 4 0 0 1-.583.786"/><path d="M3.477 15.104a4 4 0 0 0-.583-.786"/><path d="M9 13a4.5 4.5 0 0 0 3 4"/>',
    Droplet: '<path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.4-4 6.5S5 13 5 15a7 7 0 0 0 7 7z"/>',
    CircleDot: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="1"/>',
    Sun: '<circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>',
    Pill: '<path d="m10.5 20.5 10-10a4.95 4.95 0 1 0-7-7l-10 10a4.95 4.95 0 1 0 7 7Z"/><path d="m8.5 8.5 7 7"/>',
    Gem: '<path d="M6 3h12l4 6-10 13L2 9Z"/><path d="M11 3 8 9l4 13 4-13-3-6"/><path d="M2 9h20"/>',
  };
  return icons[name] || icons.Sparkles;
};
---

<MainLayout>
  <!-- Hero -->
  <HeroSlider client:load />

  <div class="h-1.5 chakra-gradient"></div>

  <!-- Services Preview -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <span class="text-brand-500 text-sm font-semibold tracking-wider uppercase">Nuestras Terapias</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-heading font-bold text-deep-900">
          Caminos hacia tu <span class="chakra-gradient-text">bienestar</span>
        </h2>
        <p class="mt-4 text-deep-500 leading-relaxed">
          Cada terapia es un viaje personalizado hacia el equilibrio. Descubre la modalidad que resuena con tu ser.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {therapies.slice(0, 9).map((therapy, i) => (
          <a href={`/terapias#${therapy.slug}`} class="card group p-6 text-center">
            <div class={`w-14 h-14 mx-auto rounded-2xl bg-gradient-to-br ${chakraColors[i]} flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300`}>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconSvg(therapy.icon)} />
            </div>
            <h3 class="font-heading font-semibold text-deep-800 text-lg">{therapy.name}</h3>
            <p class="mt-2 text-deep-500 text-sm leading-relaxed line-clamp-3">{therapy.description}</p>
            <div class="mt-4 flex items-center justify-center gap-3 text-xs text-deep-400 flex-wrap">
              <span class="flex items-center gap-1">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {therapy.durationMinutes} min
              </span>
              {therapy.price !== null && therapy.price > 0 ? (
                <span class="font-medium text-deep-600">
                  ${therapy.price}
                </span>
              ) : (
                <span class="text-brand-500 font-medium">Consultar</span>
              )}
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/terapias" class="btn-outline inline-flex items-center gap-2">
          Ver todas las terapias <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- About preview -->
  <section class="section-padding bg-sage-50 relative overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-1 chakra-gradient"></div>
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-sage-600 text-sm font-semibold tracking-wider uppercase">Acerca de IMHDXEIN</span>
          <h2 class="mt-3 text-3xl md:text-4xl font-heading font-bold text-deep-900">
            Medicina integrativa para tu <span class="chakra-gradient-text">sanación completa</span>
          </h2>
          <p class="mt-6 text-deep-600 leading-relaxed">
            Somos un instituto de medicina integrativa y holística que brinda atención médica psicoemocional, integrativa y holística. Acompañamos a nuestros pacientes en las 4 dimensiones del ser: física, psicológica, emocional y espiritual.
          </p>
          <p class="mt-4 text-deep-600 leading-relaxed">
            Nuestro equipo de médicos y terapeutas altamente capacitados integra la unificación de la ciencia con la espiritualidad, comprometidos con el humanismo y la salud integral de cada persona.
          </p>
          <a href="/nosotros" class="inline-flex items-center gap-2 mt-6 text-brand-600 font-semibold hover:text-brand-700 transition-colors">
            Conoce a nuestro equipo <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
        <div class="relative">
          <div class="rounded-2xl overflow-hidden shadow-2xl">
            <img src="https://images.pexels.com/photos/3872623/pexels-photo-3872623.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Espacio de meditación IMHDXEIN" class="w-full h-80 object-cover" />
          </div>
          <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl shadow-xl p-5 max-w-[220px]">
            <div class="flex items-center gap-2 mb-2">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3A7D44" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"/></svg>
              <span class="font-heading font-bold text-2xl text-deep-900">10+</span>
            </div>
            <p class="text-deep-500 text-sm">Años de experiencia en medicina holística</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section-padding bg-deep-900 relative overflow-hidden">
    <div class="absolute inset-0 lotus-bg opacity-10"></div>
    <div class="container-custom relative z-10">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <span class="text-brand-400 text-sm font-semibold tracking-wider uppercase">Testimonios</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-heading font-bold text-white">
          Voces de <span class="chakra-gradient-text">transformación</span>
        </h2>
      </div>

      <TestimonialCarousel client:load testimonials={testimonials} />
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-spirit-700 via-chakra-third to-spirit-800"></div>
    <div class="absolute inset-0 lotus-bg opacity-20"></div>
    <div class="container-custom px-4 relative z-10 text-center">
      <svg class="text-brand-300 mx-auto mb-6 animate-float" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5a3 3 0 1 1 3 3m-3-3a3 3 0 1 0-3 3m3-3v0M12 5a3 3 0 0 0-3 3v6a3 3 0 0 0 3 3m0-12c1.657 0 3 1..343 3 3v6c0 1.657-1.343 3-3 3m0-12c-1.657 0-3 1.343-3 3v6c0 1.657 1.343 3 3 3m0 0a3 3 0 0 0 3-3"/></svg>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-white">Da el primer paso hacia tu sanación</h2>
      <p class="mt-4 text-deep-200 max-w-lg mx-auto leading-relaxed">
        Agenda tu primera consulta y descubre cómo la medicina holística puede transformar tu vida.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/contacto" class="btn-primary text-base">Agendar Cita Ahora</a>
        <a href="/productos" class="btn-outline !border-white/30 !text-white hover:!bg-white/10 text-base">Ver Productos</a>
      </div>
    </div>
  </section>
</MainLayout>
