---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "IMHDXEIN - Instituto de Medicina Holística | Terapias, Productos y Citas",
  description = "IMHDXEIN - Instituto de Medicina Holística. Acupuntura, Flores de Bach, Osteopatía, Reiki, Aromaterapia, Meditación Guiada y más. Agenda tu cita hoy.",
  image = "https://images.pexels.com/photos/3872623/pexels-photo-3872623.jpeg?auto=compress&cs=tinysrgb&w=1200",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = "IMHDXEIN";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/logoimhdxein.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="medicina holística, acupuntura, flores de bach, reiki, osteopatía, aromaterapia, meditación, terapias alternativas, chakras, IMHDXEIN, CDMX" />
    <meta name="author" content="IMHDXEIN" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={image} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Structured Data: MedicalOrganization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "MedicalOrganization",
      "name": "IMHDXEIN",
      "description": "Instituto de Medicina Holística. Acupuntura, Flores de Bach, Reiki, Osteopatía y más.",
      "url": "https://imhdxein.com",
      "telephone": "+52 33 1842 2251",
      "email": "imhdxein@gmaill.com.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Calle Buenos Aires 2910, Colonia Providencia",
        "addressLocality": "Guadalajara Jalisco CP 66439",
        "addressCountry": "MX"
      }
    })} />
  </head>
  <body>
    <slot />
  </body>
</html>
